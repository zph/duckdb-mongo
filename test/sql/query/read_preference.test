# name: test/sql/query/read_preference.test
# description: Test read preference parameter and session setting
# group: [query]

require mongo

# @spec RP-SET-004
# Setting should be visible in duckdb_settings
query I
SELECT COUNT(*) FROM duckdb_settings() WHERE name = 'mongo_read_preference';
----
1

# @spec RP-SET-001
# Default value should be empty string
query I
SELECT current_setting('mongo_read_preference') = '';
----
true

# @spec RP-SET-002, RP-SET-003
# SET and RESET should work
statement ok
SET mongo_read_preference = 'secondaryPreferred';

query I
SELECT current_setting('mongo_read_preference');
----
secondaryPreferred

statement ok
RESET mongo_read_preference;

query I
SELECT current_setting('mongo_read_preference') = '';
----
true

# @spec RP-SET-002
# snake_case should work
statement ok
SET mongo_read_preference = 'secondary_preferred';

statement ok
RESET mongo_read_preference;

# @spec RP-SET-002
# Multiple SETs — last write wins
statement ok
SET mongo_read_preference = 'primary';

statement ok
SET mongo_read_preference = 'nearest';

query I
SELECT current_setting('mongo_read_preference');
----
nearest

statement ok
RESET mongo_read_preference;

# Test with actual MongoDB (requires test database)
require-env MONGODB_TEST_DATABASE_AVAILABLE

statement ok
ATTACH 'host=localhost port=27017 dbname=duckdb_mongo_test' AS mongo_test (TYPE MONGO);

# @spec RP-PARAM-001, RP-PARAM-002
# Test all valid read preference values as named parameter
query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    read_preference := 'primary'
);
----
true

query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    read_preference := 'primaryPreferred'
);
----
true

query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    read_preference := 'primary_preferred'
);
----
true

query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    read_preference := 'secondaryPreferred'
);
----
true

query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    read_preference := 'secondary_preferred'
);
----
true

query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    read_preference := 'nearest'
);
----
true

# @spec RP-PARAM-002
# Case insensitivity
query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    read_preference := 'PRIMARY'
);
----
true

query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    read_preference := 'SECONDARYPREFERRED'
);
----
true

query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    read_preference := 'Nearest'
);
----
true

# @spec RP-PARAM-004
# Empty string means use default
query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    read_preference := ''
);
----
true

# @spec RP-PARAM-003
# Invalid value should raise error
statement error
SELECT COUNT(*) FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    read_preference := 'invalid_mode'
);
----
read_preference

statement error
SELECT COUNT(*) FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    read_preference := 'replset'
);
----
read_preference

# @spec RP-ATTACH-001
# Session setting should apply to ATTACH queries
statement ok
SET mongo_read_preference = 'primaryPreferred';

query I
SELECT COUNT(*) >= 1 FROM mongo_test.users;
----
true

statement ok
RESET mongo_read_preference;

# @spec RP-PREC-001
# Named parameter should override session setting
# SET to 'primary', but use 'nearest' in named param — should not error
statement ok
SET mongo_read_preference = 'primary';

query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    read_preference := 'nearest'
);
----
true

statement ok
RESET mongo_read_preference;

# @spec RP-PREC-003
# After RESET, no read preference override (uses connection default)
query I
SELECT COUNT(*) >= 1 FROM mongo_test.users;
----
true

# @spec RP-COMPOSE-001
# Combined with after_cluster_time should work
query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    read_preference := 'primaryPreferred',
    after_cluster_time := '0:0'
);
----
true

# Both SET at session level
statement ok
SET mongo_read_preference = 'nearest';

statement ok
SET mongo_after_cluster_time = '0:0';

query I
SELECT COUNT(*) >= 1 FROM mongo_test.users;
----
true

statement ok
RESET mongo_read_preference;

statement ok
RESET mongo_after_cluster_time;

statement ok
DETACH mongo_test;
