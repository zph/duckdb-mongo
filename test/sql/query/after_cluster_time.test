# name: test/sql/query/after_cluster_time.test
# description: Test afterClusterTime causal consistency reads
# group: [query]

require mongo

# @spec ACT-SET-004
# Setting should be visible in duckdb_settings
query I
SELECT COUNT(*) FROM duckdb_settings() WHERE name = 'mongo_after_cluster_time';
----
1

# @spec ACT-SET-001
# Default value should be empty string
query I
SELECT current_setting('mongo_after_cluster_time') = '';
----
true

# @spec ACT-SET-002, ACT-SET-003
# SET and RESET should work
statement ok
SET mongo_after_cluster_time = '1779206684:15';

query I
SELECT current_setting('mongo_after_cluster_time');
----
1779206684:15

statement ok
RESET mongo_after_cluster_time;

query I
SELECT current_setting('mongo_after_cluster_time') = '';
----
true

# @spec ACT-SET-002
# UBIGINT-as-string format should also work for SET
statement ok
SET mongo_after_cluster_time = '7641659143652114433';

query I
SELECT current_setting('mongo_after_cluster_time');
----
7641659143652114433

statement ok
RESET mongo_after_cluster_time;

# @spec ACT-SET-002
# Multiple SETs — last write wins
statement ok
SET mongo_after_cluster_time = '100:1';

statement ok
SET mongo_after_cluster_time = '200:2';

query I
SELECT current_setting('mongo_after_cluster_time');
----
200:2

statement ok
RESET mongo_after_cluster_time;

# Test with actual MongoDB (requires test database)
require-env MONGODB_TEST_DATABASE_AVAILABLE

statement ok
ATTACH 'host=localhost port=27017 dbname=duckdb_mongo_test' AS mongo_test (TYPE MONGO);

# @spec ACT-COMPOSE-001
# Run a scan to capture operation time
query I
SELECT COUNT(*) >= 1 FROM mongo_test.users;
----
true

# @spec ACT-PARAM-001
# Named parameter with a literal UBIGINT value
query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    after_cluster_time := '0:1'
);
----
true

# @spec ACT-PARAM-002
# seconds:increment string format
query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    after_cluster_time := '0:0'
);
----
true

# @spec ACT-PARAM-002
# Large realistic timestamp value (seconds:increment)
query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    after_cluster_time := '1779206684:15'
);
----
true

# @spec ACT-PARAM-004
# Empty string means disabled (no afterClusterTime sent)
query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    after_cluster_time := ''
);
----
true

# @spec ACT-PARAM-003
# Invalid input should raise error
statement error
SELECT COUNT(*) FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    after_cluster_time := 'not_a_timestamp'
);
----
after_cluster_time

statement error
SELECT COUNT(*) FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    after_cluster_time := 'abc:def'
);
----
after_cluster_time

# @spec ACT-SET-002, ACT-ATTACH-001
# Session setting should apply to ATTACH queries
statement ok
SET mongo_after_cluster_time = '0:0';

query I
SELECT COUNT(*) >= 1 FROM mongo_test.users;
----
true

statement ok
RESET mongo_after_cluster_time;

# @spec ACT-PREC-001
# Named parameter should override session setting
statement ok
SET mongo_after_cluster_time = '999999999:1';

# The session has an unreachable future timestamp, but the named param overrides with 0:0
query I
SELECT COUNT(*) >= 1 FROM mongo_scan(
    'mongodb://localhost:27017',
    'duckdb_mongo_test',
    'users',
    after_cluster_time := '0:0'
);
----
true

statement ok
RESET mongo_after_cluster_time;

# @spec ACT-PREC-003
# After RESET, no afterClusterTime applied
query I
SELECT COUNT(*) >= 1 FROM mongo_test.users;
----
true

# @spec ACT-COMPOSE-001
# Full workflow: capture operation time, use it for causal read via SET
# (subqueries not allowed in named params, so use SET VARIABLE + session setting)
statement ok
SET VARIABLE act = (SELECT COALESCE(mongo_operation_time()::VARCHAR, ''));

statement ok
SET mongo_after_cluster_time = getvariable('act');

query I
SELECT COUNT(*) >= 1 FROM mongo_test.users;
----
true

statement ok
RESET mongo_after_cluster_time;

statement ok
DETACH mongo_test;
